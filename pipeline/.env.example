# Telegram (create the bot via @BotFather)
TELEGRAM_BOT_TOKEN=
# random string you also pass to Telegram's setWebhook — rejects spoofed webhooks
TELEGRAM_WEBHOOK_SECRET_TOKEN=
# your numeric Telegram user id (ask @userinfobot) — the bot ignores everyone else
TELEGRAM_ALLOWED_USER_ID=

# Notion internal integration token (share your article pages with the integration!)
NOTION_TOKEN=

# OpenRouter (https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=
# optional overrides (defaults: anthropic/claude-sonnet-5, google/gemini-2.5-flash-image)
# the image model must support image output via chat completions (modalities: image)
# TEXT_MODEL=
# IMAGE_MODEL=

# GitHub fine-grained PAT with Contents read/write on the site repo
GITHUB_TOKEN=
# GITHUB_REPO=jozefcipa/jozefcipa.com
# SITE_DEFAULT_BRANCH=master

# AWS IAM user scoped to s3://<bucket>/blog/*
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
# ASSETS_BASE_URL=https://assets.jozefcipa.com

# used to compute preview deployment URLs: <project>-git-<branch>-<team>.vercel.app
SITE_VERCEL_PROJECT_NAME=
VERCEL_TEAM_SLUG=
# SITE_BASE_URL=https://jozefcipa.com
